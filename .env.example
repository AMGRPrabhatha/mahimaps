PORT=3000

# SMTP (Spaceship Spacemail)
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_SECURE=false
SMTP_REQUIRE_TLS=true

# Mailbox credentials
EMAIL_USER=your-mailbox@yourdomain.com
EMAIL_PASS=your-mailbox-password

# Sender and receiver
EMAIL_FROM="Mahi Maps <your-mailbox@yourdomain.com>"
RECIPIENT_EMAIL=your-mailbox@yourdomain.com
